#!/usr/bin/env bash
# Run the New Music Fridays routine from the terminal in test or fast mode.
#
# Usage:
#   ./scripts/nmf --test    full Last.fm + web research; subject prefixed [TEST]; sent
#   ./scripts/nmf --fast    trimmed Last.fm + stubbed candidates; subject prefixed [TEST][FAST]; sent
#                           (--fast implies --test)
#
# Production mode is reserved for the scheduled Friday run, which fires SKILL.md via
# the scheduled-task runtime with no env vars set. The wrapper script never produces
# production-mode runs — that's intentional, so a manual invocation can't accidentally
# send an unmarked production email.

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ $# -eq 0 ]]; then
  echo "Usage: $0 [--test] [--fast]" >&2
  echo "  --test  send email with [TEST] prefix; full Last.fm + web research" >&2
  echo "  --fast  send email with [TEST][FAST] prefix; trimmed Last.fm, stubbed candidates; implies --test" >&2
  exit 1
fi

for arg; do
  case "$arg" in
    --test)
      export NMF_TEST=1
      ;;
    --fast)
      export NMF_FAST=1
      export NMF_TEST=1
      ;;
    -h|--help)
      echo "Usage: $0 [--test] [--fast]"
      echo "  --test  send email with [TEST] prefix; full Last.fm + web research"
      echo "  --fast  send email with [TEST][FAST] prefix; trimmed Last.fm, stubbed candidates; implies --test"
      exit 0
      ;;
    *)
      echo "Unknown flag: $arg" >&2
      echo "Run '$0 --help' for usage." >&2
      exit 1
      ;;
  esac
done

exec claude --model opus --effort max -p -- "$(cat SKILL.md)"
